# Copy this file to .env for backend-only Docker deployment.
# cp .env.backend.example .env

# AI model keys (set at least one provider key)
# --- GEMINI API ---
# GEMINI_API_KEY=YOUR_GEMINI_API_KEY
GEMINI_MODEL_NAME=gemini-3.1-flash-lite-preview

# --- ANTHROPIC API ---
# ANTHROPIC_API_KEY=YOUR_ANTHROPIC_API_KEY
CLAUDE_MODEL_NAME=claude-sonnet-4-5-20250929

# --- OPENAI API ---
# OPENAI_API_KEY=YOUR_OPENAI_API_KEY
OPENAI_MODEL_NAME=gpt-4o

# Local Postgres in docker-compose.backend.yml
POSTGRES_DB=code_alchemist
POSTGRES_USER=postgres
POSTGRES_PASSWORD=postgres
DATABASE_URL=postgresql://postgres:postgres@db:5432/code_alchemist

# Security
SECRET_KEY=generate_a_random_secret_key_here
JWT_SECRET_KEY=c92b6bccaabaaf2c21af135bec684e51ab7702c591b0239ff2035842c60c0da1

# Optional web search provider config
WEB_SEARCH_PROVIDER=tavily
# TAVILY_API_KEY=YOUR_TAVILY_API_KEY

# Optional
CORS_ORIGINS=*
RESEND_API_KEY=
MAIL_FROM=CodeAlchemist <noreply@example.com>
