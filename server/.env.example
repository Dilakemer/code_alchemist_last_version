# ===========================================
# CodeAlchemist Environment Variables
# ===========================================
# Bu dosyayı .env olarak kopyalayın ve değerleri doldurun
# UYARI: .env dosyasını asla Git'e commit etmeyin!

# --- AI API Keys ---
GEMINI_API_KEY=your_gemini_api_key_here
GEMINI_MODEL_NAME=gemini-2.5-pro

ANTHROPIC_API_KEY=your_anthropic_api_key_here
CLAUDE_MODEL_NAME=claude-sonnet-4-5-20250929

OPENAI_API_KEY=your_openai_api_key_here
OPENAI_MODEL_NAME=gpt-4o

# --- Web Search Provider ---
# Seçenekler: duckduckgo | serper | tavily | brave
WEB_SEARCH_PROVIDER=tavily
# Tavily için bu anahtar yeterlidir.
TAVILY_API_KEY=tvly-xxxxxxxxxx
# Alternatif sağlayıcı anahtarları (isteğe bağlı):
# SERPER_API_KEY=your_serper_api_key_here
# BRAVE_SEARCH_API_KEY=your_brave_api_key_here
# Ortak fallback anahtarı (provider-specific key yoksa kullanılır):
# WEB_SEARCH_API_KEY=your_web_search_api_key_here

# --- JWT Güvenlik Anahtarı ---
# Production için güçlü bir rastgele string kullanın
JWT_SECRET_KEY=your-secure-random-jwt-secret-key
GOOGLE_CLIENT_ID=your_google_oauth_client_id_here

# --- Email Konfigürasyonu ---
# Resend API (Production için ÖNERİLEN)
# https://resend.com adresinden ücretsiz API key alın
RESEND_API_KEY=re_xxxxxxxxxx
MAIL_FROM=CodeAlchemist <noreply@yourdomain.com>

# SMTP Fallback (İsteğe Bağlı - Development için)
# Resend API key yoksa bu ayarlar kullanılır
# MAIL_SERVER=smtp.gmail.com
# MAIL_PORT=587
# MAIL_USERNAME=your_email@gmail.com
# MAIL_PASSWORD=your_app_password
